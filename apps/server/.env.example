PORT=4000
MONGO_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/local-legend
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
PUBLIC_BASE_URL=https://your-host.example.com
CORS_ORIGIN=*
GOOGLE_MAPS_API_KEY=
# Email of the account auto-promoted to admin on startup (can delete any gem)
ADMIN_EMAIL=
# Path to the Firebase service-account JSON for FCM push. Unset → push disabled.
FCM_SERVICE_ACCOUNT_PATH=
# Latest Android native build runtimeVersion; older clients get nagged to update.
APP_LATEST_RUNTIME_VERSION=1.2.0
ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.shishir48.locallegend
